	<subDataset name="dsServiciosExtras" uuid="c6dfbfc4-50e7-4d7b-8724-633d8eae8f6e">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="325"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="667"/>
		<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w1" value="517"/>
		<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w2" value="471"/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL-Gestion-Azure.jrdax"/>
		<parameter name="folioSalidaSrv" class="java.lang.String">
			<defaultValueExpression><![CDATA[$P{folioSalidaSrv}]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT 
    srv.SERVICIO_DS AS Servicio, 
    ss.nu_cantidad AS Cantidad,
    udm.unidad_de_manejo_ds
FROM servicios_salida AS ss
INNER JOIN salida AS s ON s.cd_salida = ss.cd_salida 
INNER JOIN servicio AS srv ON srv.SERVICIO_CVE = ss.servicio_cve 
LEFT OUTER JOIN unidad_de_manejo udm ON ss.unidad_de_manejo_cve  = udm.UNIDAD_DE_MANEJO_CVE 
WHERE s.cd_folio_salida = $P{folioSalidaSrv}
ORDER BY srv.SERVICIO_DS]]>
		</queryString>
		<field name="Servicio" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="SERVICIO_DS"/>
			<property name="com.jaspersoft.studio.field.label" value="Servicio"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="SERVICIO"/>
		</field>
		<field name="unidad_de_manejo_ds" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="UNIDAD_DE_MANEJO_DS"/>
			<property name="com.jaspersoft.studio.field.label" value="unidad_de_manejo_ds"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="UNIDAD_DE_MANEJO"/>
		</field>
		<field name="Cantidad" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.name" value="nu_cantidad"/>
			<property name="com.jaspersoft.studio.field.label" value="Cantidad"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="servicios_salida"/>
		</field>
	</subDataset>
	<parameter name="folioSalida" class="java.lang.String"/>
	<parameter name="idPlanta" class="java.lang.Integer"/>
	<parameter name="esHorarioEspecial" class="java.lang.Boolean"/>
	<parameter name="logoPath" class="java.lang.String">
		<defaultValueExpression><![CDATA[new String("/logo.jpeg")]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
	cte.CTE_NOMBRE,
	cdd.folio_cliente,
    s.cd_folio_salida,
    s.fh_salida,
    s.tm_salida,
    s.nb_placas_transporte,
    s.nb_nombre_transportista,
    sd.partida_cve,
    prd.numero_prod,
    prd.producto_ds,
    dp.dtp_codigo,
    dp.dtp_caducidad,
    dp.dtp_PO,
    dp.dtp_MP,
    dp.dtp_pedimento,
    dp.dtp_SAP,
    dp.dtp_lote,
    p.cantidad_total,
    sd.nu_cantidad,
    udm.unidad_de_manejo_ds,
    p.peso_total,
    CAST((p.peso_total / p.cantidad_total) * sd.nu_cantidad as DECIMAL(9,3)) AS nu_peso_aprox,
    plt.planta_abrev,
    plt.planta_ds,
    plt.id_usuario,
    plt.nb_ubicacion,
    pa.pais_desc,
    ed.estado_desc,
    mn.municipio_ds,
    cd.ciudad_ds,
    ah.cp,
    ah.asentamiento_ds,
    ta.tipoasntmnto_ds,
    plt.nb_calle,
    plt.nu_exterior,
    plt.nu_interior,
    usr.usuario,
    usr.mail,
    s.nb_observaciones,
    cto.nb_nombre,
    cto.nb_apellido_1,
    cto.nb_apellido_2
from salida s
inner join salida_detalle sd ON s.cd_salida  = sd.cd_salida 
inner join partida p ON p.partida_cve = sd.partida_cve
inner join constancia_de_deposito cdd ON p.FOLIO = cdd.FOLIO
inner join cliente cte on cdd.CTE_CVE = cte.CTE_CVE
inner join (
    select tdp.* from detalle_partida tdp
    inner join (select partida_cve, max(det_part_cve) as det_part_cve from detalle_partida group by partida_cve) tmdp
     on tdp.partida_cve = tmdp.partida_cve and tdp.det_part_cve = tmdp.det_part_cve
) dp on dp.partida_cve = p.partida_cve
inner join camara c ON c.camara_cve = p.camara_cve
inner join planta plt ON plt.planta_cve = c.planta_cve
inner join unidad_de_producto udp ON p.unidad_de_producto_cve = udp.unidad_de_producto_cve
inner join unidad_de_manejo udm ON udp.unidad_de_manejo_cve = udm.unidad_de_manejo_cve
inner join producto prd ON udp.producto_cve = prd.producto_cve
left outer join asentamiento_humano ah ON plt.id_pais = ah.pais_cve
	AND plt.id_estado = ah.estado_cve
	AND plt.id_municipio = ah.municipio_cve 
	AND plt.id_ciudad = ah.ciudad_cve 
	AND plt.id_asentamiento = ah.asentamiento_cve 
	AND plt.tp_asentamiento = ah.tipoasntmnto_cve
left outer join tipo_asentamiento ta ON ah.tipoasntmnto_cve = ta.tipoasntmnto_cve
left outer join ciudades cd ON ah.pais_cve = cd.pais_cve
	AND ah.estado_cve = cd.estado_cve
	AND ah.municipio_cve = cd.municipio_cve 
	AND ah.ciudad_cve  = cd.ciudad_cve
left outer join municipios mn ON cd.pais_cve = mn.pais_cve
	AND cd.estado_cve = mn.estado_cve
	AND cd.municipio_cve = mn.municipio_cve
left outer join estados ed ON mn.pais_cve = ed.pais_cve
	AND mn.estado_cve = ed.estado_cve
left outer join paises pa ON ed.pais_cve = pa.pais_cve
left outer join usuario usr ON plt.id_usuario = usr.id
left outer join cliente_contacto ccto ON s.id_contacto = ccto.id_contacto
left outer join contacto cto ON ccto.id_contacto = cto.id_contacto
where s.cd_folio_salida = $P{folioSalida} and plt.planta_cve = $P{idPlanta}]]>
	</queryString>
